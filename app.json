{
  "expo": {
    "name": "Olympy",
    "slug": "olympy_mobile_rn",
    "version": "1.0.0",
    "scheme": "olympy",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F4FBF8",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/72f6f8f1-3ef0-4d9d-b888-492116c2d98a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.prolymp.olympy"
    },
    "android": {
      "package": "uz.prolymp.olympy",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F4FBF8"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Olympy profil rasmingizni yuklash uchun galereyaga ruxsat so'raydi."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "72f6f8f1-3ef0-4d9d-b888-492116c2d98a"
      }
    },
    "owner": "benxur"
  }
}
